    "schemas": {
      "EventBulkExportJobCreateQuery": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/EventBulkExportJobCreateQueryResourceObject"
          }
        },
        "required": [
          "data"
        ]
      },
      "EventBulkExportJobCreateQueryResourceObject": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/EventBulkExportJobEnum"
          },
          "attributes": {
            "type": "object",
            "properties": {
              "start_date": {
                "description": "Start date for the export range in ISO 8601 format with timezone (e.g., '2024-01-01T00:00:00Z').",
                "type": "string",
                "format": "date-time",
                "example": "2024-01-01T00:00:00Z"
              },
              "end_date": {
                "description": "End date for the export range in ISO 8601 format with timezone (e.g., '2024-01-31T23:59:59Z'). Must be after start_date and not in the future. Date range cannot exceed 90 days.",
                "type": "string",
                "format": "date-time",
                "example": "2024-01-31T23:59:59Z"
              },
              "properties": {
                "description": "List of event property keys to export.",
                "type": "array",
                "items": {
                  "type": "string"
                },
                "example": [
                  "customer.addresses[*].alias",
                  "total_paid_tax_excl"
                ],
                "nullable": true
              }
            },
            "required": [
              "start_date",
              "end_date"
            ]
          },
          "relationships": {
            "type": "object",
            "properties": {
              "metric": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "object",
                    "properties": {
                      "type": {
                        "$ref": "#/components/schemas/MetricEnum"
                      },
                      "id": {
                        "description": "The metric to export events from.",
                        "type": "string",
                        "example": "ABC123"
                      }
                    },
                    "required": [
                      "type",
                      "id"
                    ]
                  }
                }
              }
            },
            "required": [
              "metric"
            ]
          }
        },
        "required": [
          "type",
          "attributes",
          "relationships"
        ]
      },
      "EventBulkExportJobEnum": {
        "type": "string",
        "enum": [
          "event-bulk-export-job"
        ]
      },
      "MetricEnum": {
        "type": "string",
        "enum": [
          "metric"
        ]
      },
      "ObjectLinks": {
        "type": "object",
        "properties": {
          "self": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "self"
        ]
      },
      "PostEventBulkExportJobCreateResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "type": {
                "$ref": "#/components/schemas/EventBulkExportJobEnum"
              },
              "id": {
                "description": "Unique identifier for the export job.",
                "type": "string",
                "example": "01GSQPBF74KQ5YTDEPP41T1BZH"
              },
              "attributes": {
                "type": "object",
                "properties": {
                  "status": {
                    "description": "Current status of the export job. Always 'processing' when first created.",
                    "type": "string",
                    "example": "processing",
                    "enum": [
                      "complete",
                      "expired",
                      "failed",
                      "processing"
                    ]
                  },
                  "created_at": {
                    "description": "Date and time the job was created in ISO 8601 format (YYYY-MM-DDTHH:MM:SS.mmmmmm).",
                    "type": "string",
                    "format": "date-time",
                    "example": "2022-11-08T00:00:00+00:00"
                  }
                },
                "required": [
                  "status",
                  "created_at"
                ]
              },
              "relationships": {
                "type": "object",
                "properties": {
                  "metric": {
                    "type": "object",
                    "properties": {
                      "data": {
                        "type": "object",
                        "properties": {
                          "type": {
                            "$ref": "#/components/schemas/MetricEnum"
                          },
                          "id": {
                            "description": "The metric that events are exported from.",
                            "type": "string",
                            "example": "ABC123"
                          }
                        },
                        "required": [
                          "type",
                          "id"
                        ]
                      },
                      "links": {
                        "$ref": "#/components/schemas/RelationshipLinks"
                      }
                    }
                  }
                }
              },
              "links": {
                "$ref": "#/components/schemas/ObjectLinks"
              }
            },
            "required": [
              "type",
              "id",
              "attributes",
              "links"
            ]
          },
          "links": {
            "$ref": "#/components/schemas/ObjectLinks"
          }
        },
        "required": [
          "data"
        ]
      },
      "RelationshipLinks": {
        "type": "object",
        "properties": {
          "self": {
            "type": "string",
            "format": "uri"
          },
          "related": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "self",
          "related"
        ]
      }
    },
