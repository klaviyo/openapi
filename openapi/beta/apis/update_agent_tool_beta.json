      },
      "AgentToolCustomUpdateDetails": {
        "type": "object",
        "properties": {
          "type": {
            "description": "Update detail variant for custom HTTPS tools.",
            "$ref": "#/components/schemas/CustomEnum"
          },
          "protocol": {
            "description": "Message protocol for the tool. `https` is currently supported.",
            "$ref": "#/components/schemas/AgentToolMessageProtocol",
            "nullable": true
          },
          "request_template": {
            "description": "Sparse update for the templated outbound HTTPS request configuration.",
            "$ref": "#/components/schemas/AgentToolHTTPSRequestTemplateUpdate",
            "nullable": true
          },
          "variables": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AgentToolVariable",
              "description": "Replacement list of template variables referenced by the URL, query parameters, headers, or body."
            },
            "nullable": true
          },
          "timeout_seconds": {
            "description": "Overall tool execution timeout in seconds. Must be greater than 0 and at most 10.",
            "type": "integer",
            "nullable": true
          },
          "max_retries": {
            "description": "Maximum retry attempts for the tool call. Must be between 0 and 3.",
            "type": "integer",
            "nullable": true
          }
