    "schemas": {
      "EventBulkExportJobEnum": {
        "type": "string",
        "enum": [
          "event-bulk-export-job"
        ]
      },
      "EventBulkExportJobStatusRetrieveResponseObjectResource": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/EventBulkExportJobEnum"
          },
          "id": {
            "description": "Unique identifier for the export job.",
            "type": "string",
            "example": "01GSQPBF74KQ5YTDEPP41T1BZH"
          },
          "attributes": {
            "type": "object",
            "properties": {
              "status": {
                "description": "Current status of the export job.",
                "type": "string",
                "example": "processing",
                "enum": [
                  "complete",
                  "expired",
                  "failed",
                  "processing"
                ]
              },
              "result": {
                "description": "Result of the export job containing the download URL. Only present when status is 'complete'.",
                "$ref": "#/components/schemas/ExportResult",
                "nullable": true
              },
              "error": {
                "description": "Error message if the export job failed. Only present when status is 'failed'.",
                "type": "string",
                "nullable": true
              }
            },
            "required": [
              "status"
            ]
          },
          "relationships": {
            "type": "object",
            "properties": {
              "metric": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "object",
                    "properties": {
                      "type": {
                        "$ref": "#/components/schemas/MetricEnum"
                      },
                      "id": {
                        "description": "The metric that events are exported from.",
                        "type": "string",
                        "example": "ABC123"
                      }
                    },
                    "required": [
                      "type",
                      "id"
                    ]
                  },
                  "links": {
                    "$ref": "#/components/schemas/RelationshipLinks"
                  }
                }
              }
            }
          },
          "links": {
            "$ref": "#/components/schemas/ObjectLinks"
          }
        },
        "required": [
          "type",
          "id",
          "attributes",
          "links"
        ]
      },
      "ExportResult": {
        "type": "object",
        "properties": {
          "expires_at": {
            "description": "Date and time when the export file expires in ISO 8601 format.",
            "type": "string",
            "format": "date-time",
            "example": "2025-10-07T12:00:00Z"
          }
        },
        "required": [
          "expires_at"
        ]
      },
      "GetEventBulkExportJobStatusRetrieveResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/EventBulkExportJobStatusRetrieveResponseObjectResource"
          },
          "links": {
            "$ref": "#/components/schemas/ObjectLinks"
          }
        },
        "required": [
          "data"
        ]
      },
