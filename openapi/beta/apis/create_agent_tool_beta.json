      "AgentToolCustomCreateDetailsRequest": {
        "type": "object",
        "properties": {
          "type": {
            "description": "Create detail variant for custom HTTPS tools.",
            "$ref": "#/components/schemas/CustomEnum"
          },
          "protocol": {
            "description": "Message protocol for the tool. `https` is currently supported.",
            "type": "string",
            "example": "https",
            "default": "https",
            "enum": [
              "https"
            ]
          },
          "request_template": {
            "description": "Templated outbound HTTPS request configuration.",
            "$ref": "#/components/schemas/AgentToolHTTPSRequestTemplateRequest"
          },
          "variables": {
            "description": "Template variables referenced by the URL, query parameters, headers, or body. To reference a secret, include a variable with `source: secret` and `value` set to the `agent-secret` id.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AgentToolVariableRequest"
            },
            "default": []
          },
          "timeout_seconds": {
            "description": "Overall tool execution timeout in seconds. Must be greater than 0 and at most 10.",
            "type": "integer",
            "example": 5,
            "default": 5
          },
          "max_retries": {
            "description": "Maximum retry attempts for the tool call. Must be between 0 and 3.",
            "type": "integer",
            "example": 1,
            "default": 1
          }
        },
        "required": [
          "type",
          "request_template"
        ]
      },
      "AgentToolCustomReadDetails": {
