    "schemas": {
      "AudienceInlineCreate": {
        "type": "object",
        "properties": {
          "temporary_id": {
            "description": "Client-supplied temporary ID. Messages reference this value via audience_temporary_id to establish the audience-message relationship.",
            "type": "string",
            "example": "aud_01HTXYZ"
          },
          "name": {
            "description": "The name of the audience",
            "type": "string",
            "example": "My Audience",
            "nullable": true
          },
          "included": {
            "description": "The list of included group IDs",
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "abc123"
            ],
            "nullable": true
          },
          "excluded": {
            "description": "The list of excluded group IDs",
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "abc123"
            ],
            "nullable": true
          }
        },
        "required": [
          "temporary_id"
        ]
      },
      "CampaignAudienceEnum": {
        "type": "string",
        "enum": [
          "campaign-audience"
        ]
      },
      "CampaignCreateQuery": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/CampaignCreateQueryResourceObject"
          }
        },
        "required": [
          "data"
        ]
      },
      "CampaignCreateQueryResourceObject": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/CampaignEnum"
          },
          "attributes": {
            "type": "object",
            "properties": {
              "definition": {
                "description": "The campaign definition containing audiences and optional messages",
                "$ref": "#/components/schemas/CampaignDefinition"
              },
              "messages": {
                "description": "Messages to create on this campaign. Each references an audience via audience_temporary_id.",
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/MessageInlineCreate"
                },
                "nullable": true
              },
              "audiences": {
                "description": "Audiences to create on this campaign. Each references a message via audience_temporary_id.",
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/AudienceInlineCreate"
                },
                "nullable": true
              }
            },
            "required": [
              "definition"
            ]
          },
          "relationships": {
            "type": "object",
            "properties": {
              "campaign-audiences": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "type",
                        "id"
                      ],
                      "properties": {
                        "type": {
                          "$ref": "#/components/schemas/CampaignAudienceEnum"
                        },
                        "id": {
                          "description": "The audiences associated with the campaign",
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              },
              "campaign-messages": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "type",
                        "id"
                      ],
                      "properties": {
                        "type": {
                          "$ref": "#/components/schemas/CampaignMessageEnum"
                        },
                        "id": {
                          "description": "The messages associated with the campaign",
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              },
              "tags": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "type",
                        "id"
                      ],
                      "properties": {
                        "type": {
                          "$ref": "#/components/schemas/TagEnum"
                        },
                        "id": {
                          "description": "The tags associated with the campaign",
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "required": [
          "type",
          "attributes"
        ]
      },
      "CampaignDefinition": {
        "type": "object",
        "properties": {
          "name": {
            "description": "The campaign name",
            "type": "string",
            "nullable": true
          },
          "builder": {
            "description": "Builder type: canvas or wizard",
            "type": "string",
            "example": "canvas",
            "nullable": true
          },
          "archived": {
            "description": "Whether the campaign has been archived",
            "type": "boolean",
            "nullable": true
          },
          "color": {
            "description": "Campaign display color as a hex string (e.g. 'ff5733')",
            "type": "string",
            "nullable": true
          },
          "description": {
            "description": "A short description of the campaign",
            "type": "string",
            "nullable": true
          },
          "send_settings": {
            "description": "Campaign-level send configuration",
            "$ref": "#/components/schemas/SendSettings",
            "nullable": true
          }
        }
      },
      "CampaignEnum": {
        "type": "string",
        "enum": [
          "campaign"
        ]
      },
      "CampaignMessageEnum": {
        "type": "string",
        "enum": [
          "campaign-message"
        ]
      },
      "EmailChannelDetails": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "example": "email",
            "default": "email",
            "enum": [
              "email"
            ]
          },
          "template_id": {
            "type": "string",
            "nullable": true
          },
          "from_label": {
            "type": "string",
            "default": ""
          },
          "from_email": {
            "type": "string",
            "default": ""
          },
          "reply_to_email": {
            "type": "string",
            "default": ""
          },
          "cc_email": {
            "type": "string",
            "default": ""
          },
          "bcc_email": {
            "type": "string",
            "default": ""
          },
          "subject": {
            "type": "string",
            "default": ""
          },
          "preview_text": {
            "type": "string",
            "default": ""
          }
        }
      },
      "MessageInlineCreate": {
        "type": "object",
        "properties": {
          "audience_temporary_id": {
            "description": "Must match a temporary_id in the definition.audiences array.",
            "type": "string"
          },
          "name": {
            "description": "Message display name",
            "type": "string",
            "nullable": true
          },
          "is_add_utm": {
            "description": "Whether to add UTM parameters to links in this message",
            "type": "boolean",
            "nullable": true
          },
          "throttling_type": {
            "description": "Smart sending throttling configuration for this message",
            "type": "string",
            "enum": [
              "FOR_CAMPAIGNS",
              "FOR_CAMPAIGNS_AND_FLOWS",
              "FOR_FLOWS",
              "NONE"
            ],
            "nullable": true
          },
          "variations": {
            "description": "Inline variations for this message. Default variation created if omitted.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VariationInlineCreate"
            },
            "nullable": true
          }
        },
        "required": [
          "audience_temporary_id"
        ]
      },
      "ObjectLinks": {
        "type": "object",
        "properties": {
          "self": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "self"
        ]
      },
      "PostCampaignResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "type": {
                "$ref": "#/components/schemas/CampaignEnum"
