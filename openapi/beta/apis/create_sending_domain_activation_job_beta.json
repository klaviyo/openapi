      "PostSendingDomainActivationJobResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "type": {
                "$ref": "#/components/schemas/SendingDomainActivationJobEnum"
              },
              "id": {
                "description": "The ID of the activation job.",
                "type": "string",
                "example": "act_01JE3Z5PSNKN9V9TRGQ1N6V782"
              },
              "attributes": {
                "type": "object",
                "properties": {
                  "status": {
                    "description": "The lifecycle status of the sending domain after the activation attempt.",
                    "type": "string",
                    "enum": [
                      "active",
                      "pending",
                      "warming"
                    ]
                  },
                  "activated_at": {
                    "description": "ISO8601 timestamp when activation was requested.",
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-04-23T00:00:00Z"
                  }
                },
                "required": [
                  "status",
                  "activated_at"
                ]
              },
