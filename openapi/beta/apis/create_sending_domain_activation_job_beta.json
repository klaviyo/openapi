            "type": "object",
            "properties": {
              "warming_enabled": {
                "description": "Whether to warm send volume on activation. Not supported if you have only one domain. Defaults to True if you have multiple domains.",
                "type": "boolean",
                "nullable": true
              }
            }
          },
          "relationships": {
            "type": "object",
