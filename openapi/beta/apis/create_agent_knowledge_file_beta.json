    }
  },
  "servers": [
    {
      "url": "https://a.klaviyo.com",
      "description": "Production"
    }
  ],
  "security": [
    {
      "Klaviyo-API-Key": []
    }
  ],
  "paths": {
    "/api/agent-knowledge-files": {
      "post": {
        "operationId": "create_agent_knowledge_file_beta",
        "summary": "Create Agent Knowledge File",
        "description": "\n            > \ud83d\udea7 This endpoint is in beta and subject to change.\n            >\n            > A beta revision header (2026-04-15.pre) is required to use our beta APIs. Klaviyo APIs in beta are not intended for use in production. See our [versioning and deprecation policy](https://developers.klaviyo.com/en/docs/api_versioning_and_deprecation_policy) for more information.\n\nUploads a file (PDF, DOCX, TXT, etc.) and indexes its contents as\nAgent Knowledge with ``source_type: file``.\n\nReturns the new Agent Knowledge resource immediately; clients\ncan poll its ``status`` until indexing completes.<br><br>*Rate limits*:<br>Burst: `10/s`<br>Steady: `150/m`\n\n**Scopes:**\n`agents:write`\n\n[OpenAPI Spec](https://raw.githubusercontent.com/klaviyo/openapi/main/openapi/beta/apis/create_agent_knowledge_file_beta.json)",
        "parameters": [
          {
            "name": "fields[agent-knowledge]",
            "in": "query",
            "description": "For more information please visit https://developers.klaviyo.com/en/v2026-04-15.pre/reference/api-overview#sparse-fieldsets",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "created_at",
                  "error",
                  "id",
                  "indexed_at",
                  "source",
                  "source.auto_reindex",
                  "source.content",
                  "source.scope",
                  "source.source_type",
                  "source.title",
                  "source.url",
                  "status",
                  "updated_at"
                ]
              }
            },
            "explode": false
          },
          {
            "name": "revision",
            "in": "header",
            "description": "API endpoint revision (format: YYYY-MM-DD[.suffix])",
            "required": true,
            "schema": {
              "type": "string",
              "default": "2026-04-15.pre"
            }
          }
        ],
        "requestBody": {
          "description": "Multipart body for creating file-backed Agent Knowledge.",
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/AgentKnowledgeUploadRequestDataWrapper"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Success",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentKnowledgeResponseDataWrapper"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/ClientError"
          },
          "5XX": {
            "$ref": "#/components/responses/ServerError"
          }
        },
        "tags": [
          "Beta APIs"
        ],
        "x-klaviyo-pre-release": "BETA",
        "x-klaviyo-ratelimit": {
          "burst": "10/s",
          "steady": "150/m"
        },
        "x-klaviyo-scopes": [
          "agents:write"
        ],
        "x-klaviyo-subtag": "Customer Agent"
      }
    }
  },
  "components": {
    "responses": {
      "ClientError": {
        "description": "Client Error",
        "content": {
          "application/vnd.api+json": {
            "schema": {
              "type": "object",
              "properties": {
                "errors": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "id",
                      "code",
                      "title",
                      "detail"
                    ],
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "code": {
                        "type": "string"
                      },
                      "title": {
                        "type": "string"
                      },
                      "detail": {
                        "type": "string"
                      },
                      "source": {
                        "type": "object",
                        "properties": {
                          "pointer": {
                            "type": "string"
                          },
                          "parameter": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              },
              "required": [
                "errors"
              ]
            }
          }
        }
      },
      "ServerError": {
        "description": "Server Error",
        "content": {
          "application/vnd.api+json": {
            "schema": {
              "type": "object",
              "properties": {
                "errors": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "id",
                      "code",
                      "title",
                      "detail"
                    ],
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "code": {
                        "type": "string"
                      },
                      "title": {
                        "type": "string"
                      },
                      "detail": {
                        "type": "string"
                      },
                      "source": {
                        "type": "object",
                        "properties": {
                          "pointer": {
                            "type": "string"
                          },
                          "parameter": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              },
              "required": [
                "errors"
              ]
            }
          }
        }
      }
    },
    "schemas": {
      "AgentKnowledgeFileResponseSource": {
        "type": "object",
        "properties": {
          "source_type": {
            "description": "The knowledge item was created from an uploaded file.",
            "$ref": "#/components/schemas/FileEnum"
          },
          "title": {
            "description": "Human-readable title for the file-backed knowledge item.",
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "source_type"
        ]
      },
      "AgentKnowledgeResourceName": {
        "type": "string",
        "enum": [
          "agent-knowledge"
        ]
      },
      "AgentKnowledgeResponse": {
        "type": "object",
        "properties": {
          "source": {
            "description": "Source payload for the knowledge item.",
            "oneOf": [
              {
                "$ref": "#/components/schemas/AgentKnowledgeSnippetResponseSource"
              },
              {
                "$ref": "#/components/schemas/AgentKnowledgeWebpageResponseSource"
              },
              {
                "$ref": "#/components/schemas/AgentKnowledgeFileResponseSource"
              }
            ]
          },
          "status": {
            "description": "Indexing lifecycle state for the knowledge item.",
            "type": "string",
            "enum": [
              "pending",
              "indexing",
              "indexed",
              "failed",
              "rejected"
            ]
          },
          "created_at": {
            "description": "Date and time when the knowledge item was created.",
            "type": "string",
            "format": "date-time",
            "example": "2022-11-08T00:00:00+00:00"
          },
          "updated_at": {
            "description": "Date and time when the knowledge item was last updated.",
            "type": "string",
            "format": "date-time",
            "example": "2022-11-08T00:00:00+00:00"
          },
          "indexed_at": {
            "description": "Date and time when indexing completed, if available.",
            "type": "string",
            "format": "date-time",
            "example": "2022-11-08T00:00:00+00:00",
            "nullable": true
          },
          "error": {
            "description": "Error message when indexing failed; otherwise null.",
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "source",
          "status",
          "created_at",
          "updated_at"
        ]
      },
      "AgentKnowledgeResponseData": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/AgentKnowledgeResourceName"
          },
          "id": {
            "description": "Unique Agent Knowledge identifier.",
            "type": "string"
          },
          "attributes": {
            "$ref": "#/components/schemas/AgentKnowledgeResponse"
          },
          "links": {
            "$ref": "#/components/schemas/ObjectLinks"
          }
        },
        "required": [
          "type",
          "id",
          "attributes",
          "links"
        ]
      },
      "AgentKnowledgeResponseDataWrapper": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/AgentKnowledgeResponseData"
          },
          "links": {
            "$ref": "#/components/schemas/ObjectLinks"
          }
        },
        "required": [
          "data"
        ]
      },
      "AgentKnowledgeSnippetResponseSource": {
        "type": "object",
        "properties": {
          "source_type": {
            "description": "The knowledge item was created from caller-provided content.",
            "$ref": "#/components/schemas/SnippetEnum"
          },
          "title": {
            "description": "Human-readable title for the snippet.",
            "type": "string",
            "nullable": true
          },
          "content": {
            "description": "Text body for the snippet.",
            "nullable": true,
            "type": "string"
          }
        },
        "required": [
          "source_type"
        ]
      },
      "AgentKnowledgeUploadRequestDataWrapper": {
        "type": "object",
        "properties": {
          "title": {
            "description": "Human-readable title for the file-backed knowledge item.",
            "type": "string"
          },
          "file": {
            "description": "File to upload and index as Agent Knowledge.",
            "type": "string",
            "format": "binary"
          }
        },
        "required": [
          "title",
          "file"
        ]
      },
      "AgentKnowledgeWebpageResponseSource": {
        "type": "object",
        "properties": {
          "source_type": {
            "description": "The knowledge item was created from a webpage.",
            "$ref": "#/components/schemas/WebpageEnum"
          },
          "url": {
            "description": "Normalized URL for the webpage-backed knowledge item.",
            "type": "string",
            "nullable": true
          },
          "scope": {
            "description": "Crawl scope for the webpage-backed knowledge item.",
            "type": "string",
            "enum": [
              "single-page",
              "entire-site"
            ],
            "nullable": true
          },
          "auto_reindex": {
            "description": "Whether the webpage is periodically re-indexed.",
            "type": "boolean",
            "nullable": true
          }
        },
        "required": [
          "source_type"
        ]
      },
      "FileEnum": {
        "type": "string",
        "enum": [
          "file"
        ]
      },
      "ObjectLinks": {
        "type": "object",
        "properties": {
          "self": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "self"
        ]
      },
      "SnippetEnum": {
        "type": "string",
        "enum": [
          "snippet"
        ]
      },
      "WebpageEnum": {
        "type": "string",
        "enum": [
          "webpage"
        ]
      }
    },
    "securitySchemes": {
      "Klaviyo-API-Key": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Private key authentication for /api/ endpoints is performed by setting the `Authorization` header to `Klaviyo-API-Key your-private-api-key`<br>For more information please visit https://developers.klaviyo.com/en/v2026-04-15.pre/reference/api-overview#authentication",
        "x-default": "Klaviyo-API-Key your-private-api-key"
      }
    }
  },
  "tags": [
    {
      "name": "Beta APIs",
      "description": "beta apis"
    }
  ]
}
