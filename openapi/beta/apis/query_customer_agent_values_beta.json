    "schemas": {
      "CustomerAgentValuesReportQuery": {
        "type": "object",
        "properties": {
          "statistics": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValuesStatistic",
              "description": "Metrics to compute for each grouping bucket. Combine volume and resolution-rate in one call to receive both per bucket."
            }
          },
          "timeframe": {
            "description": "Time window for the report.",
            "$ref": "#/components/schemas/ReportTimeframe"
          },
          "groupings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValuesGrouping",
              "default": [],
              "description": "Optional dimension to break the result down by. Provide exactly one of channel or status, or omit entirely for a single aggregate row."
            }
          }
        },
        "required": [
          "statistics",
          "timeframe",
          "groupings"
        ]
      },
      "CustomerAgentValuesReportQueryRequestData": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/CustomerAgentValuesReportResourceName"
          },
          "attributes": {
            "$ref": "#/components/schemas/CustomerAgentValuesReportQuery"
          }
        },
        "required": [
          "type",
          "attributes"
        ]
      },
      "CustomerAgentValuesReportQueryRequestDataWrapper": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/CustomerAgentValuesReportQueryRequestData"
          }
        },
        "required": [
          "data"
        ]
      },
      "CustomerAgentValuesReportResourceName": {
        "type": "string",
        "enum": [
          "customer-agent-values-report"
        ]
      },
      "CustomerAgentValuesReportResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValuesData",
              "description": "Computed values-report rows."
            }
          }
        },
        "required": [
          "results"
        ]
      },
      "CustomerAgentValuesReportResponseData": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/CustomerAgentValuesReportResourceName"
          },
          "id": {
            "description": "Opaque identifier for the values report response.",
            "type": "string"
          },
          "attributes": {
            "$ref": "#/components/schemas/CustomerAgentValuesReportResponse"
          },
          "links": {
            "$ref": "#/components/schemas/ObjectLinks"
          }
        },
        "required": [
          "type",
          "id",
          "attributes",
          "links"
        ]
      },
      "CustomerAgentValuesReportResponseDataWrapper": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/CustomerAgentValuesReportResponseData"
          },
          "links": {
            "$ref": "#/components/schemas/ObjectLinks"
          }
        },
        "required": [
          "data",
          "links"
        ]
      },
      "ObjectLinks": {
        "type": "object",
        "properties": {
          "self": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "self"
        ]
      },
      "ReportTimeframe": {
        "type": "object",
        "properties": {
          "key": {
            "description": "Named preset window.",
            "$ref": "#/components/schemas/TimeframeKey",
            "nullable": true
          },
          "start": {
            "description": "ISO-8601 lower-bound (inclusive) for the report window.",
            "type": "string",
            "format": "date-time",
            "example": "2026-05-01T00:00:00+00:00",
            "nullable": true
          },
          "end": {
            "description": "ISO-8601 upper-bound (exclusive) for the report window.",
            "type": "string",
            "format": "date-time",
            "example": "2026-06-01T00:00:00+00:00",
            "nullable": true
          }
        }
      },
      "TimeframeKey": {
        "type": "string",
        "enum": [
          "today",
          "yesterday",
          "this_week",
          "last_week",
          "last_7_days",
          "last_30_days",
          "last_90_days",
          "this_month",
          "last_month"
        ]
      },
      "ValuesData": {
        "type": "object",
        "properties": {
          "groupings": {
            "description": "Bucket-identifying values for this row. Empty when the request omits groupings for a single aggregate row.",
            "type": "object"
          },
          "statistics": {
            "description": "Computed metrics for this row. Only the statistics named in the request appear here.",
            "type": "object"
          }
        },
        "required": [
          "groupings",
          "statistics"
        ]
      },
      "ValuesGrouping": {
        "type": "string",
        "enum": [
          "channel",
          "status"
        ]
      },
      "ValuesStatistic": {
        "type": "string",
        "enum": [
          "volume",
          "resolution-rate"
        ]
      }
    },
    "securitySchemes": {
      "Klaviyo-API-Key": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Private key authentication for /api/ endpoints is performed by setting the `Authorization` header to `Klaviyo-API-Key your-private-api-key`<br>For more information please visit https://developers.klaviyo.com/en/v2026-04-15.pre/reference/api-overview#authentication",
        "x-default": "Klaviyo-API-Key your-private-api-key"
      }
    }
  },
