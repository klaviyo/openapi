    "schemas": {
      "CampaignMessageEnum": {
        "type": "string",
        "enum": [
          "campaign-message"
        ]
      },
      "CampaignMessageScheduleEnum": {
        "type": "string",
        "enum": [
          "campaign-message-schedule"
        ]
      },
      "CampaignMessageScheduleQuery": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/CampaignMessageScheduleQueryResourceObject"
          }
        },
        "required": [
          "data"
        ]
      },
      "CampaignMessageScheduleQueryResourceObject": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/CampaignMessageScheduleEnum"
          },
          "attributes": {
            "type": "object",
            "properties": {
              "send_time": {
                "description": "The datetime at which the message should be sent (must be in the future). Required when strategy is not 'smart_send_time'.",
                "type": "string",
                "format": "date-time",
                "example": "2026-08-01T14:30:00+00:00",
                "nullable": true
              },
              "send_date": {
                "description": "The date on which the message should be sent. Required when strategy is 'smart_send_time'. Must not be in the past.",
                "type": "string",
                "format": "date",
                "example": "2026-08-01",
                "nullable": true
              },
              "strategy": {
                "description": "The send strategy to use: static, local_timezone, throttled, or smart_send_time",
                "type": "string",
                "example": "static",
                "enum": [
                  "local_timezone",
                  "smart_send_time",
                  "static",
                  "throttled"
                ]
              },
              "throttled_options": {
                "description": "Required when strategy is 'throttled'. Configuration for throttled sending.",
                "$ref": "#/components/schemas/ThrottledOptions",
                "nullable": true
              },
              "timezone_options": {
                "description": "Optional when strategy is 'local_timezone'. Configuration for timezone-based sending.",
                "$ref": "#/components/schemas/TimezoneOptions",
                "nullable": true
              }
            },
            "required": [
              "strategy"
            ]
          },
          "relationships": {
            "type": "object",
            "properties": {
              "campaign-message": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "object",
                    "properties": {
                      "type": {
                        "$ref": "#/components/schemas/CampaignMessageEnum"
                      },
                      "id": {
                        "description": "The campaign message to schedule",
                        "type": "string"
                      }
                    },
                    "required": [
                      "type",
                      "id"
                    ]
                  }
                }
              }
            },
            "required": [
              "campaign-message"
            ]
          }
        },
        "required": [
          "type",
          "attributes",
          "relationships"
        ]
      },
      "CampaignMessageScheduleUpdateQuery": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/CampaignMessageScheduleUpdateQueryResourceObject"
          }
        },
        "required": [
          "data"
        ]
      },
      "CampaignMessageScheduleUpdateQueryResourceObject": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/CampaignMessageScheduleEnum"
          },
          "id": {
            "type": "string"
          },
          "attributes": {
            "type": "object",
            "properties": {
              "action": {
                "description": "The action to take: 'cancel' or 'revert'",
                "type": "string",
                "example": "cancel",
                "enum": [
                  "cancel",
                  "revert"
                ]
              }
            },
            "required": [
              "action"
            ]
          }
        },
        "required": [
          "type",
          "id",
          "attributes"
        ]
      },
      "ObjectLinks": {
        "type": "object",
        "properties": {
          "self": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "self"
        ]
      },
      "PostCampaignMessageScheduleResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "type": {
                "$ref": "#/components/schemas/CampaignMessageScheduleEnum"
              },
              "id": {
                "description": "The ID of the scheduled campaign message",
                "type": "string",
                "example": "925e385b52fb405715f3616c337cc65c"
              },
              "attributes": {
                "type": "object",
                "properties": {
                  "send_time": {
                    "description": "The datetime at which the message is scheduled to send. Null for smart_send_time strategy.",
                    "type": "string",
                    "format": "date-time",
                    "example": "2022-11-08T00:00:00+00:00",
                    "nullable": true
                  },
                  "send_date": {
                    "description": "The date on which the message is scheduled to send (present for smart_send_time strategy)",
                    "type": "string",
                    "format": "date",
                    "nullable": true
                  },
                  "strategy": {
                    "description": "The send strategy used for scheduling",
                    "type": "string",
                    "enum": [
                      "local_timezone",
                      "smart_send_time",
                      "static",
                      "throttled"
                    ]
                  }
                },
                "required": [
                  "strategy"
                ]
              },
              "relationships": {
                "type": "object",
                "properties": {
                  "campaign-message": {
                    "type": "object",
                    "properties": {
                      "data": {
                        "type": "object",
                        "properties": {
                          "type": {
                            "$ref": "#/components/schemas/CampaignMessageEnum"
                          },
                          "id": {
                            "description": "Related Campaign Message",
                            "type": "string"
                          }
                        },
                        "required": [
                          "type",
                          "id"
                        ]
                      },
                      "links": {
                        "$ref": "#/components/schemas/RelationshipLinks"
                      }
                    }
                  }
                }
              },
              "links": {
                "$ref": "#/components/schemas/ObjectLinks"
              }
            },
            "required": [
              "type",
              "id",
              "attributes",
              "links"
            ]
          },
          "links": {
            "$ref": "#/components/schemas/ObjectLinks"
          }
        },
        "required": [
          "data"
        ]
      },
      "RelationshipLinks": {
        "type": "object",
        "properties": {
          "self": {
            "type": "string",
            "format": "uri"
          },
          "related": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "self",
          "related"
        ]
      },
      "ThrottledOptions": {
        "type": "object",
        "properties": {
          "throttling_percentage": {
            "description": "Percentage of recipients to send to per hour (10, 11, 13, 14, 17, 20, 25, 33, or 50)",
            "type": "integer",
            "example": 20
          }
        },
        "required": [
          "throttling_percentage"
        ]
      },
      "TimezoneOptions": {
        "type": "object",
        "properties": {
          "send_past_timezones_tomorrow": {
            "description": "If true, recipients in timezones where the send time has already passed will receive the message the following day. If false, they receive it immediately.",
            "type": "boolean",
            "default": false,
            "nullable": true
          }
        }
      }
    },
    "securitySchemes": {
      "Klaviyo-API-Key": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Private key authentication for /api/ endpoints is performed by setting the `Authorization` header to `Klaviyo-API-Key your-private-api-key`<br>For more information please visit https://developers.klaviyo.com/en/v2026-04-15.pre/reference/api-overview#authentication",
        "x-default": "Klaviyo-API-Key your-private-api-key"
      }
    }
  },
  "tags": [
    {
      "name": "Beta APIs",
      "description": "beta apis"
    }
  ]
}
