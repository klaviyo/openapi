    "schemas": {
      "AgentKnowledgeCreateRequest": {
        "type": "object",
        "properties": {
          "source": {
            "description": "Source payload for the new item. `snippet` requires `title` and `content`; `webpage` requires `url` and does not accept caller-provided content. To upload a file, use `POST /agent-knowledge-files`.",
            "oneOf": [
              {
                "$ref": "#/components/schemas/AgentKnowledgeSnippetCreateSource"
              },
              {
                "$ref": "#/components/schemas/AgentKnowledgeWebpageCreateSource"
              }
            ]
          }
        },
        "required": [
          "source"
        ]
      },
      "AgentKnowledgeCreateRequestRequestData": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/AgentKnowledgeResourceName"
          },
          "attributes": {
            "$ref": "#/components/schemas/AgentKnowledgeCreateRequest"
          }
        },
        "required": [
          "type",
          "attributes"
        ]
      },
      "AgentKnowledgeCreateRequestRequestDataWrapper": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/AgentKnowledgeCreateRequestRequestData"
          }
        },
        "required": [
          "data"
        ]
      },
      "AgentKnowledgeFileResponseSource": {
        "type": "object",
        "properties": {
          "source_type": {
            "description": "The knowledge item was created from an uploaded file.",
            "$ref": "#/components/schemas/FileEnum"
          },
          "title": {
            "description": "Human-readable title for the file-backed knowledge item.",
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "source_type"
        ]
      },
      "AgentKnowledgeResourceName": {
        "type": "string",
        "enum": [
          "agent-knowledge"
        ]
      },
      "AgentKnowledgeResponse": {
        "type": "object",
        "properties": {
          "source": {
            "description": "Source payload for the knowledge item.",
            "oneOf": [
              {
                "$ref": "#/components/schemas/AgentKnowledgeSnippetResponseSource"
              },
              {
                "$ref": "#/components/schemas/AgentKnowledgeWebpageResponseSource"
              },
              {
                "$ref": "#/components/schemas/AgentKnowledgeFileResponseSource"
              }
            ]
          },
          "status": {
            "description": "Indexing lifecycle state for the knowledge item.",
            "$ref": "#/components/schemas/AgentKnowledgeStatus"
          },
          "created_at": {
            "description": "Date and time when the knowledge item was created.",
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "description": "Date and time when the knowledge item was last updated.",
            "type": "string",
            "format": "date-time"
          },
          "indexed_at": {
            "description": "Date and time when indexing completed, if available.",
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "error": {
            "description": "Error message when indexing failed; otherwise null.",
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "source",
          "status",
          "created_at",
          "updated_at"
        ]
      },
      "AgentKnowledgeResponseData": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/AgentKnowledgeResourceName"
          },
          "id": {
            "description": "Unique Agent Knowledge identifier.",
            "type": "string"
          },
          "attributes": {
            "$ref": "#/components/schemas/AgentKnowledgeResponse"
          },
          "links": {
            "$ref": "#/components/schemas/ObjectLinks"
          }
        },
        "required": [
          "type",
          "id",
          "attributes",
          "links"
        ]
      },
      "AgentKnowledgeResponseDataWrapper": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/AgentKnowledgeResponseData"
          },
          "links": {
            "$ref": "#/components/schemas/ObjectLinks"
          }
        },
        "required": [
          "data",
          "links"
        ]
      },
      "AgentKnowledgeSnippetCreateSource": {
        "type": "object",
        "properties": {
          "source_type": {
            "description": "Create a text snippet from caller-provided content.",
            "$ref": "#/components/schemas/SnippetEnum"
          },
          "title": {
            "description": "Human-readable title for the snippet.",
            "type": "string"
          },
          "content": {
            "description": "Text body for the snippet.",
            "type": "string"
          }
        },
        "required": [
          "source_type",
          "title",
          "content"
        ]
      },
