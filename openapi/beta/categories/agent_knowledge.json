          "indexed",
          "failed",
          "rejected"
        ]
      },
      "AgentKnowledgeUpdateRequest": {
        "type": "object",
        "properties": {
          "title": {
            "description": "Human-readable title for the snippet.",
            "type": "string",
            "nullable": true
          },
          "content": {
            "description": "Text body for the snippet. Re-indexing is automatic when changed.",
            "nullable": true,
            "type": "string"
          }
        }
      },
      "AgentKnowledgeUpdateRequestRequestData": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/AgentKnowledgeResourceName"
          },
          "id": {
            "description": "Agent Knowledge identifier. This must match the `agent_knowledge_id` path parameter.",
            "type": "string"
          },
          "attributes": {
            "$ref": "#/components/schemas/AgentKnowledgeUpdateRequest"
          }
        },
        "required": [
          "type",
          "id",
          "attributes"
        ]
      },
      "AgentKnowledgeUpdateRequestRequestDataWrapper": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/AgentKnowledgeUpdateRequestRequestData"
          }
        },
        "required": [
          "data"
        ]
      },
      "AgentKnowledgeWebpageCreateSource": {
        "type": "object",
        "properties": {
          "source_type": {
            "description": "Create a webpage-backed knowledge source from a URL.",
            "$ref": "#/components/schemas/WebpageEnum"
          },
          "url": {
            "description": "URL to scrape and index.",
            "type": "string"
          },
          "scope": {
            "description": "Crawl scope for the webpage. `single-page` indexes only the given URL; `entire-site` crawls URLs listed in the site's root sitemap.",
            "default": "single-page",
            "$ref": "#/components/schemas/AgentKnowledgeWebpageScope"
          },
