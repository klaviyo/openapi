    "schemas": {
      "AgentSecretCreateRequest": {
        "type": "object",
        "properties": {
          "name": {
            "description": "Display name for the secret. Leading and trailing whitespace is stripped before validation; the resulting name must be non-empty. Not the alias used in tool configs.",
            "type": "string",
            "example": "Order API key"
          },
          "value": {
            "description": "Plaintext secret value. Must be non-empty. Encrypted prior to persistence and never returned in any response.",
            "type": "string",
            "example": "sk_live_example"
          }
        },
        "required": [
          "name",
          "value"
        ]
      },
      "AgentSecretCreateRequestRequestData": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/AgentSecretResourceName"
          },
          "attributes": {
            "$ref": "#/components/schemas/AgentSecretCreateRequest"
          }
        },
        "required": [
          "type",
          "attributes"
        ]
      },
      "AgentSecretCreateRequestRequestDataWrapper": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/AgentSecretCreateRequestRequestData"
          }
        },
        "required": [
          "data"
        ]
      },
      "AgentSecretResourceName": {
        "type": "string",
        "enum": [
          "agent-secret"
        ]
      },
      "AgentSecretResponse": {
        "type": "object",
        "properties": {
          "name": {
            "description": "Display name for the secret.",
            "type": "string",
            "example": "Order API key"
          },
          "mask": {
            "description": "Last 3 characters of the plaintext value, for visual disambiguation. The plaintext itself is never returned.",
            "type": "string",
            "example": "**********ken"
          },
          "created_at": {
            "description": "Date and time when the secret was created.",
            "type": "string",
            "format": "date-time",
            "example": "2026-05-13T12:00:00+00:00"
