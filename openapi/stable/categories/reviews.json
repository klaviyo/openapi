      "GetReviewResponseDTOCollectionCompoundDocument": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ReviewResponseDTOObjectResource"
            }
          },
          "links": {
