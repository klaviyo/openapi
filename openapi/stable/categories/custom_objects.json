        "x-klaviyo-pre-release": "None",
        "x-klaviyo-ratelimit": {
          "burst": "3/s",
          "steady": "60/m"
        },
        "x-klaviyo-scopes": [
          "custom-objects:read"
        ]
      },
      "delete": {
        "operationId": "delete_data_source",
        "summary": "Delete Data Source",
