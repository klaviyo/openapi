                          "required": [
                            "type",
                            "id"
                          ],
                          "properties": {
                            "type": {
                              "$ref": "#/components/schemas/SegmentEnum"
                            },
                            "id": {
                              "description": "Suppress/Unsuppress all profiles in this segment",
                              "type": "string",
                              "example": "Y6nRLr"
                            }
                          }
                        }
                      },
                      "links": {
